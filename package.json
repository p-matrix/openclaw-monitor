{
  "name": "@pmatrix/openclaw-monitor",
  "version": "0.6.1",
  "description": "P-MATRIX runtime governance monitor for OpenClaw — Safety Gate, Kill Switch, Live Grade",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "openclaw-monitor": "./dist/cli/setup.js"
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@pmatrix/core-sdk": "^0.1.0",
    "@pmatrix/field-node-runtime": "^0.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "openclaw",
    "pmatrix",
    "safety",
    "monitoring",
    "governance",
    "agent",
    "hooks",
    "field",
    "protocol",
    "state-vector"
  ],
  "author": "P-MATRIX <architect@p-matrix.io>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/p-matrix/openclaw-monitor/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://github.com/p-matrix/openclaw-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-matrix/openclaw-monitor.git"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "signing": {
    "method": "sigstore-cosign",
    "version": 1,
    "identity_pattern": "https://github.com/p-matrix/pmatrix-platform/.github/workflows/plugin-sign.yml.*",
    "issuer": "https://token.actions.githubusercontent.com",
    "verify_command": "bash server/scripts/verify_plugin.sh --pkg <name> --version <semver> --tgz <pkg>.tgz --sig <pkg>.sig --crt <pkg>.crt",
    "status": "skeleton-v0",
    "doc": "docs/active/security/PLUGIN_SIGNING.md"
  }
}
