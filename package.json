{
  "name": "@pmatrix/openclaw-monitor",
  "version": "0.3.5",
  "description": "Real-time safety monitoring plugin for OpenClaw agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "openclaw-monitor": "./dist/cli/setup.js"
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "keywords": [
    "openclaw",
    "pmatrix",
    "safety",
    "monitoring",
    "governance",
    "agent",
    "hooks"
  ],
  "author": "P-MATRIX <architect@p-matrix.io>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/p-matrix/openclaw-monitor/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "homepage": "https://github.com/p-matrix/openclaw-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-matrix/openclaw-monitor.git"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
